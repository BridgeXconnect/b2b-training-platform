# Environment Configuration for B2B English Training Platform

# API Configuration
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# CopilotKit Configuration
OPENAI_API_KEY=your_openai_api_key_here
NEXT_PUBLIC_COPILOT_CLOUD_API_KEY=your_copilot_cloud_api_key_here

# Application Configuration
NEXT_PUBLIC_APP_NAME=B2B English Training Platform
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Auth Configuration
JWT_SECRET=your_jwt_secret_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here

# Database Configuration (if needed for direct access)
DATABASE_URL=postgresql://username:password@localhost:5432/ai_language_platform

# Redis Configuration (if needed for direct access)
REDIS_URL=redis://localhost:6379

# Development
NODE_ENV=development