      {
        "name": "Health Check API",
        "description": "System health monitoring with detailed status checks for AI services, configuration, usage monitoring, and BMAD system",
        "files": [
          "app/api/health/route.ts",
          "lib/ai-config.ts",
          "lib/usage-monitor.ts",
          "lib/error-handler.ts"
        ],
        "api_doc": {
          "openapi": "3.0.0",
          "info": {
            "title": "Health Check API",
            "version": "1.0.0"
          },
          "paths": {
            "/api/health": {
              "get": {
                "summary": "Get system health status",
                "parameters": [
                  {
                    "name": "detailed",
                    "in": "query",
                    "schema": {
                      "type": "boolean"
                    },
                    "description": "Include detailed health information"
                  }
                ],
                "responses": {
                  "200": {
                    "description": "System healthy",
                    "content": {
                      "application/json": {
                        "schema": {
                          "type": "object",
                          "properties": {
                            "status": {
                              "type": "string"
                            },
                            "timestamp": {
                              "type": "string"
                            },
                            "services": {
                              "type": "object",
                              "properties": {
                                "config": {
                                  "type": "string"
                                },
                                "ai": {
                                  "type": "string"
                                },
                                "usage": {
                                  "type": "string"
                                },
                                "bmad": {
                                  "type": "string"
                                }
                              }
                            },
                            "version": {
                              "type": "string"
                            }
                          }
                        }
                      }
                    }
                  },
                  "206": {
                    "description": "System degraded"
                  },
                  "503": {
                    "description": "System unhealthy"
                  }
                }
              },
              "post": {
                "summary": "Execute health actions",
                "requestBody": {
                  "content": {
                    "application/json": {
                      "schema": {
                        "type": "object",
                        "properties": {
                          "action": {
                            "type": "string",
                            "enum": [
                              "reset-errors",
                              "validate-config",
                              "test-ai"
                            ]
                          }
                        }
                      }
                    }
                  }
                },
                "responses": {
                  "200": {
                    "description": "Action completed successfully"
                  },
                  "400": {
                    "description": "Invalid action"
                  },
                  "500": {
                    "description": "Action failed"
                  }
                }
              }
            }
          }
        }
      },
