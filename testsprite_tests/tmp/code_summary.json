{
  "tech_stack": [
    "TypeScript",
    "Next.js 14",
    "React 18",
    "Node.js",
    "OpenAI API",
    "Tailwind CSS",
    "Python",
    "FastAPI",
    "CopilotKit",
    "Sentry",
    "Zustand",
    "Zod"
  ],
  "features": [
    {
      "name": "Health Check API",
      "description": "System health monitoring with detailed status checks for AI services, configuration, usage monitoring, and BMAD system",
      "files": ["app/api/health/route.ts", "lib/ai-config.ts", "lib/usage-monitor.ts", "lib/error-handler.ts"],
      "api_doc": {
        "openapi": "3.0.0",
        "info": {
          "title": "Health Check API",
          "version": "1.0.0"
        },
        "paths": {
          "/api/health": {
            "get": {
              "summary": "Get system health status",
              "parameters": [
                {
                  "name": "detailed",
                  "in": "query",
                  "schema": { "type": "boolean" },
                  "description": "Include detailed health information"
                }
              ],
              "responses": {
                "200": {
                  "description": "System healthy",
                  "content": {
                    "application/json": {
                      "schema": {
                        "type": "object",
                        "properties": {
                          "status": { "type": "string" },
                          "timestamp": { "type": "string" },
                          "services": {
                            "type": "object",
                            "properties": {
                              "config": { "type": "string" },
                              "ai": { "type": "string" },
                              "usage": { "type": "string" },
                              "bmad": { "type": "string" }
                            }
                          },
                          "version": { "type": "string" }
                        }
                      }
                    }
                  }
                },
                "206": { "description": "System degraded" },
                "503": { "description": "System unhealthy" }
              }
            },
            "post": {
              "summary": "Execute health actions",
              "requestBody": {
                "content": {
                  "application/json": {
                    "schema": {
                      "type": "object",
                      "properties": {
                        "action": {
                          "type": "string",
                          "enum": ["reset-errors", "validate-config", "test-ai"]
                        }
                      }
                    }
                  }
                }
              },
              "responses": {
                "200": { "description": "Action completed successfully" },
                "400": { "description": "Invalid action" },
                "500": { "description": "Action failed" }
              }
            }
          }
        }
      }
    },
    {
      "name": "AI Chat API",
      "description": "Main chat interface with OpenAI integration, CEFR-based responses, usage monitoring, and error handling",
      "files": ["app/api/chat/route.ts", "lib/ai-config.ts", "lib/usage-monitor.ts", "lib/error-handler.ts", "lib/agents/api-integration.ts"],
      "api_doc": {
        "openapi": "3.0.0",
        "info": {
          "title": "AI Chat API",
          "version": "1.0.0"
        },
        "paths": {
          "/api/chat": {
            "post": {
              "summary": "Send chat message to AI",
              "requestBody": {
                "content": {
                  "application/json": {
                    "schema": {
                      "type": "object",
                      "properties": {
                        "message": { "type": "string" },
                        "settings": {
                          "type": "object",
                          "properties": {
                            "cefrLevel": { "type": "string" },
                            "businessContext": { "type": "string" },
                            "learningGoals": { "type": "array", "items": { "type": "string" } },
                            "userId": { "type": "string" }
                          }
                        },
                        "sessionId": { "type": "string" },
                        "messages": {
                          "type": "array",
                          "items": {
                            "type": "object",
                            "properties": {
                              "role": { "type": "string", "enum": ["system", "user", "assistant"] },
                              "content": { "type": "string" }
                            }
                          }
                        }
                      },
                      "required": ["message"]
                    }
                  }
                }
              },
              "responses": {
                "200": {
                  "description": "AI response generated",
                  "content": {
                    "application/json": {
                      "schema": {
                        "type": "object",
                        "properties": {
                          "content": { "type": "string" },
                          "cefrLevel": { "type": "string" },
                          "messageType": { "type": "string" },
                          "sessionId": { "type": "string" },
                          "usage": {
                            "type": "object",
                            "properties": {
                              "inputTokens": { "type": "number" },
                              "outputTokens": { "type": "number" },
                              "totalTokens": { "type": "number" },
                              "estimatedCost": { "type": "number" },
                              "model": { "type": "string" }
                            }
                          },
                          "userStats": {
                            "type": "object",
                            "properties": {
                              "tokensRemaining": { "type": "number" },
                              "budgetRemaining": { "type": "number" }
                            }
                          }
                        }
                      }
                    }
                  }
                },
                "400": { "description": "Invalid request" },
                "429": { "description": "Rate limit exceeded" },
                "503": { "description": "Service unavailable" }
              }
            }
          }
        }
      }
    },
    {
      "name": "AI Content Generation API",
      "description": "Generate structured learning content (lessons, quizzes, vocabulary, dialogues, business cases) with OpenAI",
      "files": ["app/api/ai/generate/route.ts"],
      "api_doc": {
        "openapi": "3.0.0",
        "info": {
          "title": "AI Content Generation API",
          "version": "1.0.0"
        },
        "paths": {
          "/api/ai/generate": {
            "post": {
              "summary": "Generate learning content using AI",
              "requestBody": {
                "content": {
                  "application/json": {
                    "schema": {
                      "type": "object",
                      "properties": {
                        "prompt": { "type": "string" },
                        "contentType": {
                          "type": "string",
                          "enum": ["lesson", "quiz", "vocabulary", "dialogue", "business-case", "roleplay"],
                          "default": "lesson"
                        },
                        "model": { "type": "string", "default": "gpt-4-turbo-preview" },
                        "temperature": { "type": "number", "default": 0.7 },
                        "maxTokens": { "type": "number", "default": 4000 }
                      },
                      "required": ["prompt"]
                    }
                  }
                }
              },
              "responses": {
                "200": {
                  "description": "Content generated successfully",
                  "content": {
                    "application/json": {
                      "schema": {
                        "type": "object",
                        "properties": {
                          "content": { "type": "string" },
                          "metadata": {
                            "type": "object",
                            "properties": {
                              "model": { "type": "string" },
                              "contentType": { "type": "string" },
                              "tokensUsed": { "type": "number" },
                              "promptTokens": { "type": "number" },
                              "completionTokens": { "type": "number" }
                            }
                          }
                        }
                      }
                    }
                  }
                },
                "400": { "description": "Invalid request" },
                "500": { "description": "Generation failed" }
              }
            }
          }
        }
      }
    },
    {
      "name": "Agent Management API",
      "description": "Discover, manage, and orchestrate multiple AI agents including BMAD system, Archon, and tmux sessions",
      "files": ["app/api/agents/route.ts", ".agent-orchestrator/services/agent-discovery-service.ts"],
      "api_doc": {
        "openapi": "3.0.0",
        "info": {
          "title": "Agent Management API",
          "version": "1.0.0"
        },
        "paths": {
          "/api/agents": {
            "get": {
              "summary": "Get agents with optional filters",
              "parameters": [
                {
                  "name": "type",
                  "in": "query",
                  "schema": { "type": "string" },
                  "description": "Filter by agent type"
                },
                {
                  "name": "status",
                  "in": "query",
                  "schema": { "type": "string" },
                  "description": "Filter by agent status"
                },
                {
                  "name": "id",
                  "in": "query",
                  "schema": { "type": "string" },
                  "description": "Get specific agent by ID"
                }
              ],
              "responses": {
                "200": {
                  "description": "Agents retrieved successfully",
                  "content": {
                    "application/json": {
                      "schema": {
                        "type": "object",
                        "properties": {
                          "summary": {
                            "type": "object",
                            "properties": {
                              "total": { "type": "number" },
                              "active": { "type": "number" },
                              "idle": { "type": "number" },
                              "error": { "type": "number" },
                              "byType": { "type": "object" }
                            }
                          },
                          "agents": { "type": "array" },
                          "timestamp": { "type": "string" }
                        }
                      }
                    }
                  }
                },
                "404": { "description": "Agent not found" },
                "500": { "description": "Discovery failed" }
              }
            },
            "post": {
              "summary": "Execute agent actions",
              "requestBody": {
                "content": {
                  "application/json": {
                    "schema": {
                      "type": "object",
                      "properties": {
                        "action": {
                          "type": "string",
                          "enum": ["start", "stop", "restart", "spawn"]
                        },
                        "agentId": { "type": "string" },
                        "params": { "type": "object" }
                      },
                      "required": ["action"]
                    }
                  }
                }
              },
              "responses": {
                "200": { "description": "Action completed successfully" },
                "400": { "description": "Invalid action" },
                "500": { "description": "Action failed" },
                "501": { "description": "Action not implemented" }
              }
            }
          }
        }
      }
    },
