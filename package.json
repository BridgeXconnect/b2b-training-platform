  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@types/node": "^20",
    "@types/react": "^18.3.14",
    "@types/react-dom": "^18.3.1",
    "eslint": "^9",
    "eslint-config-next": "^14.2.10",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "typescript": "^5"
  }
