# Local Environment Configuration Template for B2B English Training Platform
# Copy this file to .env.local and fill in your actual values

# API Configuration
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# AI Service Configuration
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_ORG_ID=your_openai_org_id_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# CopilotKit Configuration  
NEXT_PUBLIC_COPILOT_CLOUD_API_KEY=your_copilot_cloud_api_key_here

# AI Service Settings
AI_MODEL_PRIMARY=gpt-4-turbo-preview
AI_MODEL_SECONDARY=gpt-3.5-turbo
AI_MAX_TOKENS=4000
AI_TEMPERATURE=0.7
AI_REQUEST_TIMEOUT=30000
AI_MAX_RETRIES=3

# Cost & Rate Limiting
AI_MONTHLY_BUDGET_USD=1000
AI_DAILY_BUDGET_USD=50
AI_MAX_REQUESTS_PER_MINUTE=60
AI_MAX_TOKENS_PER_USER_DAILY=50000

# Content Generation Settings
CONTENT_CACHE_ENABLED=true
CONTENT_CACHE_TTL_HOURS=24
CEFR_VALIDATION_ENABLED=true
QUALITY_SCORE_THRESHOLD=0.8

# Application Configuration
NEXT_PUBLIC_APP_NAME=B2B English Training Platform
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Auth Configuration
JWT_SECRET=your_jwt_secret_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here

# Database Configuration (if needed for direct access)
DATABASE_URL=postgresql://username:password@localhost:5432/ai_language_platform

# Redis Configuration (if needed for direct access)
REDIS_URL=redis://localhost:6379

# Development - NODE_ENV inherited from .env file