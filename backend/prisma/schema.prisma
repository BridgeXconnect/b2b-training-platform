generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  SALES
  COURSE_MANAGER
  TRAINER
  STUDENT
  ADMIN
}

enum CEFRLevel {
  A1
  A2
  B1
  B2
  C1
  C2
}

enum RequestStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  REQUIRES_REVIEW
}

enum DeliveryMethod {
  IN_PERSON
  VIRTUAL
  HYBRID
}

enum Frequency {
  DAILY
  WEEKLY
  BI_WEEKLY
}

enum CourseStatus {
  GENERATED
  UNDER_REVIEW
  APPROVED
  REQUIRES_REVISION
}

enum EnrollmentStatus {
  ACTIVE
  COMPLETED
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      Role     @default(SALES)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  requests        ClientRequest[]
  assignedCourses GeneratedCourse[]
  trainerNotes    TrainerNote[]
  enrollments     CourseEnrollment[]
}

model ClientRequest {
  id              String         @id @default(cuid())
  salesRepId      String
  salesRep        User           @relation(fields: [salesRepId], references: [id], onDelete: Restrict)
  status          RequestStatus  @default(PENDING)

  companyName     String
  companyIndustry String
  companySize     Int
  contactName     String
  contactEmail    String
  contactPhone    String?
  contactPosition String

  participantCount Int
  currentLevel     CEFRLevel
  targetLevel      CEFRLevel
  departments      String[]

  goals           String[]
  painPoints      String[]
  successCriteria String[]

  totalHours       Int
  lessonsPerModule Int
  deliveryMethod   DeliveryMethod
  frequency        Frequency
  lessonDuration   Int
  preferredTimes   String[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sopDocuments SOPDocument[]
  courses      GeneratedCourse[]

  @@index([salesRepId])
}

model SOPDocument {
  id            String        @id @default(cuid())
  requestId     String
  request       ClientRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  filename      String
  fileSize      Int
  mimeType      String
  extractedText String?       @db.Text
  analysis      Json?
  createdAt     DateTime      @default(now())

  @@index([requestId])
}

model GeneratedCourse {
  id           String        @id @default(cuid())
  requestId    String
  request      ClientRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  trainerId    String?
  trainer      User?         @relation(fields: [trainerId], references: [id], onDelete: SetNull)
  title        String
  description  String        @db.Text
  cefrLevel    CEFRLevel
  totalHours   Int
  status       CourseStatus  @default(GENERATED)
  revisionNote String?       @db.Text
  modules      Json
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  trainerNotes TrainerNote[]
  enrollments  CourseEnrollment[]

  @@index([requestId])
  @@index([trainerId])
}

model TrainerNote {
  id          String          @id @default(cuid())
  courseId    String
  course      GeneratedCourse @relation(fields: [courseId], references: [id], onDelete: Cascade)
  trainerId   String
  trainer     User            @relation(fields: [trainerId], references: [id], onDelete: Cascade)
  moduleIndex Int
  lessonIndex Int
  note        String          @db.Text
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@unique([courseId, moduleIndex, lessonIndex])
  @@index([courseId])
  @@index([trainerId])
}

model CourseEnrollment {
  id         String           @id @default(cuid())
  courseId   String
  course     GeneratedCourse  @relation(fields: [courseId], references: [id], onDelete: Cascade)
  studentId  String
  student    User             @relation(fields: [studentId], references: [id], onDelete: Cascade)
  status     EnrollmentStatus @default(ACTIVE)
  enrolledAt DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  lessonProgress    LessonProgress[]
  assessmentResults AssessmentResult[]

  @@unique([courseId, studentId])
  @@index([courseId])
  @@index([studentId])
}

model LessonProgress {
  id           String           @id @default(cuid())
  enrollmentId String
  enrollment   CourseEnrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  moduleIndex  Int
  lessonIndex  Int
  completedAt  DateTime         @default(now())

  @@unique([enrollmentId, moduleIndex, lessonIndex])
  @@index([enrollmentId])
}

model AssessmentResult {
  id           String           @id @default(cuid())
  enrollmentId String
  enrollment   CourseEnrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  moduleIndex  Int
  passed       Boolean
  submittedAt  DateTime         @default(now())

  @@unique([enrollmentId, moduleIndex])
  @@index([enrollmentId])
}
